{
  "name": "DashAdmin AI Assistant",
  "nodes": [
    {
      "parameters": {
        "webhookId": "dashadmin-ai-trigger"
      },
      "type": "n8n-nodes-max.maxTrigger",
      "typeVersion": 1,
      "position": [-480, 0],
      "id": "trigger-max",
      "name": "Max Trigger",
      "credentials": { "maxApi": { "id": "MAX_API_ID", "name": "Max account" } }
    },
    {
      "parameters": {
        "url": "=https://www.mydashadmin.ru/api/bot/context",
        "queryParameters": {
          "parameters": [
            { "name": "messenger_user_id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" },
            { "name": "messenger_type", "value": "N8N" }
          ]
        },
        "options": { "response": { "response": { "neverError": true } } }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-260, 0],
      "id": "get-user-context",
      "name": "Get User Context",
      "credentials": { "httpHeaderAuth": { "id": "HEADER_AUTH_ID", "name": "Header Auth" } }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            { "id": "cond-notlinked", "leftValue": "={{ $('Get User Context').item.json.error }}", "rightValue": "User not linked", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [-40, 0],
      "id": "if-not-linked",
      "name": "If User Not Linked"
    },
    {
      "parameters": {
        "userId": "={{ $('Max Trigger').item.json.message.recipient.user_id }}",
        "text": "👋 Привет! Я DashAdmin AI.\n\nЧтобы начать:\n1. Зайдите в личный кабинет DashAdmin\n2. Нажмите Профиль → Интеграции\n3. Нажмите 'Получить код'\n\nОтправьте 6-значный код в чат.",
        "additionalFields": {}
      },
      "type": "n8n-nodes-max.max",
      "typeVersion": 1,
      "position": [180, -120],
      "id": "send-link-request",
      "name": "Send Link Request",
      "credentials": { "maxApi": { "id": "MAX_API_ID", "name": "Max account" } }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "set-prompt", "name": "prompt", "value": "={{ $('Max Trigger').item.json.message.body.text }}", "type": "string" },
            { "id": "set-user-context", "name": "userContext", "value": "={{ $('Get User Context').json }}", "type": "string" },
            { "id": "set-session-id", "name": "sessionId", "value": "=session_{{ $('Max Trigger').item.json.message.recipient.user_id }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [180, 40],
      "id": "set-fields",
      "name": "Prepare Data"
    },
    {
      "parameters": {
        "memoryType": "bufferWindow",
        "sessionsIdExpression": "={{ $('Prepare Data').item.json.sessionId }}",
        "windowSize": 10,
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1,
      "position": [140, 200],
      "id": "chat-memory",
      "name": "Chat Memory"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=КОНТЕКСТ:\n{{ JSON.stringify($('Get User Context').json) }}\n\nЗАПРОС: \"{{ $('Prepare Data').item.json.prompt }}\"\n\nПроанализируй запрос и контекст. Определи нужный API endpoint и вызови соответствующий инструмент.",
        "options": {
          "systemMessage": "=Ты — AI-ассистент DashAdmin.\n\nКОНТЕКСТ:\n{{ JSON.stringify($('Get User Context').json) }}\n\nПРАВИЛА:\n1. Если selected_club = null и запрос не содержит названия клуба — попроси выбрать клуб из available_clubs\n2. Если выбран клуб или назван клуб из списка — вызывай соответствующий инструмент\n3. Доступные инструменты: getRevenue, getShiftsSummary, getEmployees, getEmployeeHours, selectClub"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [400, 40],
      "id": "ai-agent",
      "name": "AI Agent"
    },
    {
      "parameters": { "model": "qwen/qwen3.5-flash-02-23", "options": {} },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [140, 280],
      "id": "openrouter-model",
      "name": "OpenRouter Model",
      "credentials": { "openRouterApi": { "id": "OPENROUTER_ID", "name": "OpenRouter account" } }
    },
    {
      "parameters": {
        "url": "=https://www.mydashadmin.ru/api/ai-tools/revenue",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Messenger-Type", "value": "N8N" },
            { "name": "X-Messenger-User-Id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "club_id", "value": "{{ $input.params.clubId }}" },
            { "name": "period", "value": "{{ $input.params.period }}" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [380, 340],
      "id": "tool-getRevenue",
      "name": "getRevenue"
    },
    {
      "parameters": {
        "url": "=https://www.mydashadmin.ru/api/ai-tools/shifts-summary",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Messenger-Type", "value": "N8N" },
            { "name": "X-Messenger-User-Id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "club_id", "value": "{{ $input.params.clubId }}" },
            { "name": "period", "value": "{{ $input.params.period }}" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [380, 480],
      "id": "tool-getShifts",
      "name": "getShiftsSummary"
    },
    {
      "parameters": {
        "url": "=https://www.mydashadmin.ru/api/ai-tools/employees-list",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Messenger-Type", "value": "N8N" },
            { "name": "X-Messenger-User-Id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "club_id", "value": "{{ $input.params.clubId }}" }]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [380, 620],
      "id": "tool-getEmployees",
      "name": "getEmployees"
    },
    {
      "parameters": {
        "url": "=https://www.mydashadmin.ru/api/ai-tools/employee-hours",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Messenger-Type", "value": "N8N" },
            { "name": "X-Messenger-User-Id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "employee_id", "value": "{{ $input.params.employeeId }}" },
            { "name": "period", "value": "{{ $input.params.period }}" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [380, 760],
      "id": "tool-getHours",
      "name": "getEmployeeHours"
    },
    {
      "parameters": {
        "url": "=https://www.mydashadmin.ru/api/ai-tools/select-club",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Messenger-Type", "value": "N8N" },
            { "name": "X-Messenger-User-Id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "club_id", "value": "{{ $input.params.clubId }}" }]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [380, 900],
      "id": "tool-selectClub",
      "name": "selectClub"
    },
    {
      "parameters": {
        "sendTo": "chat",
        "chatId": "={{ $('Max Trigger').item.json.message.recipient.chat_id }}",
        "text": "={{ $json.output }}",
        "additionalFields": {}
      },
      "type": "n8n-nodes-max.max",
      "typeVersion": 1,
      "position": [620, 40],
      "id": "send-response",
      "name": "Send Response",
      "credentials": { "maxApi": { "id": "MAX_API_ID", "name": "Max account" } }
    }
  ],
  "connections": {
    "Max Trigger": {
      "main": [[{ "node": "Get User Context", "type": "main", "index": 0 }]]
    },
    "Get User Context": {
      "main": [[{ "node": "If User Not Linked", "type": "main", "index": 0 }]]
    },
    "If User Not Linked": {
      "main": [
        [{ "node": "Send Link Request", "type": "main", "index": 0 }],
        [{ "node": "Prepare Data", "type": "main", "index": 0 }]
      ]
    },
    "Prepare Data": {
      "main": [[{ "node": "Chat Memory", "type": "main", "index": 0 }]]
    },
    "Chat Memory": {
      "ai_memory": [[{ "node": "AI Agent", "type": "ai_memory", "index": 0 }]]
    },
    "OpenRouter Model": {
      "ai_languageModel": [[{ "node": "AI Agent", "type": "ai_languageModel", "index": 0 }]]
    },
    "AI Agent": {
      "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]]
    },
    "getRevenue": {
      "ai_tool": [[{ "node": "AI Agent", "type": "ai_tool", "index": 0 }]]
    },
    "getShiftsSummary": {
      "ai_tool": [[{ "node": "AI Agent", "type": "ai_tool", "index": 0 }]]
    },
    "getEmployees": {
      "ai_tool": [[{ "node": "AI Agent", "type": "ai_tool", "index": 0 }]]
    },
    "getEmployeeHours": {
      "ai_tool": [[{ "node": "AI Agent", "type": "ai_tool", "index": 0 }]]
    },
    "selectClub": {
      "ai_tool": [[{ "node": "AI Agent", "type": "ai_tool", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1", "binaryMode": "separate", "availableInMCP": true },
  "versionId": "dashadmin-v3",
  "meta": { "templateCredsSetupCompleted": true },
  "id": "dashadmin-ai-workflow",
  "tags": ["dashadmin", "ai", "assistant"]
}