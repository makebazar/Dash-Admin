{
  "name": "DashAdmin AI Assistant",
  "nodes": [
    {
      "parameters": {
        "webhookId": "dashadmin-ai-trigger"
      },
      "type": "n8n-nodes-max.maxTrigger",
      "typeVersion": 1,
      "position": [-480, 0],
      "id": "trigger-max",
      "name": "Max Trigger",
      "credentials": { "maxApi": { "id": "MAX_API_ID", "name": "Max account" } }
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/bot/context",
        "queryParameters": {
          "parameters": [
            { "name": "messenger_user_id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" },
            { "name": "messenger_type", "value": "N8N" }
          ]
        },
        "options": { "response": { "response": { "neverError": true } } }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-260, 0],
      "id": "get-user-context",
      "name": "Get User Context",
      "credentials": { "reportingApiKey": { "id": "REPORTING_API_KEY_ID", "name": "Reporting API Key" } }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 3 },
          "conditions": [
            { "id": "cond-notlinked", "leftValue": "={{ $('Get User Context').item.json.error }}", "rightValue": "User not linked", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [-40, 0],
      "id": "if-not-linked",
      "name": "If User Not Linked"
    },
    {
      "parameters": {
        "userId": "={{ $('Max Trigger').item.json.message.recipient.user_id }}",
        "text": "👋 Привет! Я DashAdmin AI.\n\nЧтобы начать:\n1. Зайдите в личный кабинет DashAdmin\n2. Нажмите Профиль → Интеграции\n3. Нажмите 'Получить код'\n\nОтправьте 6-значный код в чат.",
        "additionalFields": {}
      },
      "type": "n8n-nodes-max.max",
      "typeVersion": 1,
      "position": [180, -120],
      "id": "send-link-request",
      "name": "Send Link Request",
      "credentials": { "maxApi": { "id": "MAX_API_ID", "name": "Max account" } }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "set-prompt", "name": "prompt", "value": "={{ $('Max Trigger').item.json.message.body.text }}", "type": "string" },
            { "id": "set-user-context", "name": "userContext", "value": "={{ JSON.stringify($('Get User Context').json) }}", "type": "string" },
            { "id": "set-session-id", "name": "sessionId", "value": "=session_{{ $('Max Trigger').item.json.message.recipient.user_id }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [180, 40],
      "id": "set-fields",
      "name": "Prepare Data"
    },
    {
      "parameters": {
        "memoryType": "bufferWindow",
        "sessionsIdExpression": "={{ $('Prepare Data').item.json.sessionId }}",
        "windowSize": 10,
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1,
      "position": [140, 200],
      "id": "chat-memory",
      "name": "Chat Memory"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=КОНТЕКСТ:\n{{ $('Get User Context').json | json }}\n\nЗАПРОС: \"{{ $('Prepare Data').item.json.prompt }}\"",
        "options": {
          "systemMessage": "=Ты — AI-ассистент DashAdmin.\nКонтекст содержит: user, selected_club, available_clubs, employee_clubs.\n\nПРАВИЛА:\n1. Если selected_club = null и available_clubs содержит только один клуб — автоматически используй его\n2. Если selected_club = null и клуб не определён — спроси какой клуб выбрать\n3. Для ответа вызывай toolQuery с параметрами: tool, clubId (число), period, employeeId\n\nДоступные tool:\n- getRevenue: выручка\n- getShiftsSummary: смены\n- getEmployees: список сотрудников\n- getEmployeeHours: часы сотрудника\n- selectClub: выбор клуба по clubId"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [400, 40],
      "id": "ai-agent",
      "name": "AI Agent"
    },
    {
      "parameters": { "model": "qwen/qwen3.5-flash-02-23", "options": {} },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [140, 280],
      "id": "openrouter-model",
      "name": "OpenRouter Model",
      "credentials": { "openRouterApi": { "id": "OPENROUTER_ID", "name": "OpenRouter account" } }
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/ai-tools/query",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "X-Messenger-Type", "value": "N8N" },
            { "name": "X-Messenger-User-Id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "tool", "value": "{{ $json.tool }}" },
            { "name": "clubId", "value": "{{ $json.clubId }}" },
            { "name": "employeeId", "value": "{{ $json.employeeId }}" },
            { "name": "period", "value": "{{ $json.period }}" }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequestTool",
      "typeVersion": 4.4,
      "position": [380, 200],
      "id": "tool-query",
      "name": "toolQuery"
    },
    {
      "parameters": {
        "sendTo": "chat",
        "chatId": "={{ $('Max Trigger').item.json.message.recipient.chat_id }}",
        "text": "={{ $json.output }}",
        "additionalFields": {}
      },
      "type": "n8n-nodes-max.max",
      "typeVersion": 1,
      "position": [620, 40],
      "id": "send-response",
      "name": "Send Response",
      "credentials": { "maxApi": { "id": "MAX_API_ID", "name": "Max account" } }
    }
  ],
  "connections": {
    "Max Trigger": {
      "main": [[{ "node": "Get User Context", "type": "main", "index": 0 }]]
    },
    "Get User Context": {
      "main": [[{ "node": "If User Not Linked", "type": "main", "index": 0 }]]
    },
    "If User Not Linked": {
      "main": [
        [{ "node": "Send Link Request", "type": "main", "index": 0 }],
        [{ "node": "Prepare Data", "type": "main", "index": 0 }]
      ]
    },
    "Prepare Data": {
      "main": [[{ "node": "Chat Memory", "type": "main", "index": 0 }]]
    },
    "Chat Memory": {
      "ai_memory": [[{ "node": "AI Agent", "type": "ai_memory", "index": 0 }]]
    },
    "OpenRouter Model": {
      "ai_languageModel": [[{ "node": "AI Agent", "type": "ai_languageModel", "index": 0 }]]
    },
    "AI Agent": {
      "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]]
    },
    "toolQuery": {
      "ai_tool": [[{ "node": "AI Agent", "type": "ai_tool", "index": 0 }]]
    }
  },
  "active": false,
  "settings": { "executionOrder": "v1", "binaryMode": "separate", "availableInMCP": true },
  "versionId": "dashadmin-v5",
  "meta": { "templateCredsSetupCompleted": true },
  "id": "dashadmin-ai-workflow",
  "tags": ["dashadmin", "ai", "assistant"]
}