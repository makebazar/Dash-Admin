{
  "name": "DashAdmin AI Assistant",
  "nodes": [
    {
      "parameters": { "webhookId": "dashadmin-ai-trigger" },
      "type": "n8n-nodes-max.maxTrigger",
      "typeVersion": 1,
      "position": [-480, 0],
      "id": "trigger-max",
      "name": "Max Trigger",
      "credentials": { "maxApi": { "id": "MAX_API_ID", "name": "Max account" } }
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/bot/context",
        "queryParameters": {
          "parameters": [
            { "name": "messenger_user_id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" },
            { "name": "messenger_type", "value": "N8N" }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-260, 0],
      "id": "get-user-context",
      "name": "Get User Context"
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $('Get User Context').item.json.error }}", "rightValue": "User not linked", "id": "cond-notlinked", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [-40, 0],
      "id": "if-not-linked",
      "name": "If User Not Linked"
    },
    {
      "parameters": {
        "userId": "={{ $('Max Trigger').item.json.message.recipient.user_id }}",
        "text": "Привет! Я DashAdmin AI.\n\nЧтобы начать:\n1. Зайдите в личный кабинет DashAdmin\n2. Нажмите Профиль → Интеграции\n3. Нажмите 'Получить код'\n\nОтправьте 6-значный код в чат."
      },
      "type": "n8n-nodes-max.max",
      "typeVersion": 1,
      "position": [180, -120],
      "id": "send-link-request",
      "name": "Send Link Request"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "set-prompt", "name": "prompt", "value": "={{ $('Max Trigger').item.json.message.body.text }}", "type": "string" },
            { "id": "set-session-id", "name": "sessionId", "value": "=session_{{ $('Max Trigger').item.json.message.recipient.user_id }}", "type": "string" }
          ]
        }
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [180, 40],
      "id": "prepare-data",
      "name": "Prepare Data"
    },
    {
      "parameters": {
        "memoryType": "bufferWindow",
        "sessionsIdExpression": "={{ $('Prepare Data').item.json.sessionId }}",
        "windowSize": 10
      },
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1,
      "position": [140, 200],
      "id": "chat-memory",
      "name": "Chat Memory"
    },
    {
      "parameters": {
        "model": "qwen/qwen3.5-flash-02-23"
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "typeVersion": 1,
      "position": [140, 280],
      "id": "openrouter-model",
      "name": "OpenRouter Model"
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $('Get User Context').json.available_clubs.length + $('Get User Context').json.employee_clubs.length }}", "rightValue": 1, "id": "cond-multiclub", "operator": { "type": "number", "operation": ">", "name": "filter.operator.gt" } }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [0, 180],
      "id": "check-multiple-clubs",
      "name": "If Multiple Clubs"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "build-buttons", "name": "keyboard", "value": "=[\n  {{ $('Get User Context').json.available_clubs.concat($('Get User Context').json.employee_clubs).map(c => '{\"text\":\"' + c.name + '\",\"data\":\"selectClub:' + c.id + '\"}').join(',') }}\n]", "type": "string" }
          ]
        }
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [200, 180],
      "id": "build-club-buttons",
      "name": "Build Club Buttons"
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $('Get User Context').json.selected_club }}", "rightValue": null, "id": "cond-need-select", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [400, 180],
      "id": "check-no-club",
      "name": "If No Club Selected"
    },
    {
      "parameters": {
        "userId": "={{ $('Max Trigger').item.json.message.recipient.user_id }}",
        "text": " У вас несколько клубов. Выберите клуб:",
        "keyboard": "={{ $('Build Club Buttons').item.json.keyboard }}"
      },
      "type": "n8n-nodes-max.max",
      "typeVersion": 1,
      "position": [600, 120],
      "id": "send-club-select",
      "name": "Send Club Selection"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=КОНТЕКСТ:\n{{ $('Get User Context').json | json }}\n\nЗАПРОС: \"{{ $('Prepare Data').item.json.prompt }}\"",
        "options": {
          "systemMessage": "=Ты — дружелюбный AI-ассистент для владельцев киберклубов.\nКонтекст содержит: user, selected_club, available_clubs, employee_clubs.\n\nФОРМАТЫ ОТВЕТОВ:\n- Выручка: 📊 [сумма] ₽ | Смен: [число]\n- Смены: 📅 [число] смен, [часы] часов\n- Сотрудники: 👥 [список]\n\nПРАВИЛА:\n1. Если selected_club = null и клубов > 1 — верни buttons для выбора\n2. Если clubId не передан — используй selected_club\n3. Если данных нет — \"Нет данных за период\"\n\nВЫЗЫВАЙ tool_call с параметрами:\n{\"tool\": \"getRevenue\", \"clubId\": число, \"period\": \"today|yesterday|last7days|last30days|this_month\"}\n{\"tool\": \"getShiftsSummary\", \"clubId\": число, \"period\": \"...\"}\n{\"tool\": \"getEmployees\", \"clubId\": число}\n{\"tool\": \"getEmployeeHours\", \"employeeId\": \"uuid\", \"period\": \"...\"}\n{\"tool\": \"selectClub\", \"clubId\": число}\n\nДля кнопок выбора клуба верни:\n{\"output\": \"текст\", \"buttons\": [{\"text\": \"Клуб\", \"data\": \"selectClub:ID\"}]}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [400, 40],
      "id": "ai-agent",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            { "leftValue": "={{ $json.tool }}", "rightValue": "getRevenue", "id": "r1", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } },
            { "leftValue": "={{ $json.tool }}", "rightValue": "getShiftsSummary", "id": "r2", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } },
            { "leftValue": "={{ $json.tool }}", "rightValue": "getEmployees", "id": "r3", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } },
            { "leftValue": "={{ $json.tool }}", "rightValue": "getEmployeeHours", "id": "r4", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } },
            { "leftValue": "={{ $json.tool }}", "rightValue": "selectClub", "id": "r5", "operator": { "type": "string", "operation": "equals", "name": "filter.operator.equals" } }
          ]
        }
      },
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.1,
      "position": [600, 200],
      "id": "tool-switch",
      "name": "Tool Switch"
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/ai-tools/revenue",
        "method": "GET",
        "queryParameters": {
          "parameters": [
            { "name": "clubId", "value": "={{ $json.clubId }}" },
            { "name": "period", "value": "={{ $json.period }}" }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [800, -160],
      "id": "tool-revenue",
      "name": "toolGetRevenue"
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/ai-tools/shifts-summary",
        "method": "GET",
        "queryParameters": {
          "parameters": [
            { "name": "clubId", "value": "={{ $json.clubId }}" },
            { "name": "period", "value": "={{ $json.period }}" }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [800, -80],
      "id": "tool-shifts",
      "name": "toolGetShifts"
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/ai-tools/employees-list",
        "method": "GET",
        "queryParameters": {
          "parameters": [
            { "name": "clubId", "value": "={{ $json.clubId }}" }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [800, 0],
      "id": "tool-employees",
      "name": "toolGetEmployees"
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/ai-tools/employee-hours",
        "method": "GET",
        "queryParameters": {
          "parameters": [
            { "name": "employeeId", "value": "={{ $json.employeeId }}" },
            { "name": "period", "value": "={{ $json.period }}" }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [800, 80],
      "id": "tool-employee-hours",
      "name": "toolGetEmployeeHours"
    },
    {
      "parameters": {
        "url": "https://www.mydashadmin.ru/api/ai-tools/select-club",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Messenger-Type", "value": "N8N" },
            { "name": "X-Messenger-User-Id", "value": "={{ $('Max Trigger').item.json.message.recipient.user_id }}" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"clubId\": {{ $json.clubId }}\n}"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [800, 160],
      "id": "tool-select-club",
      "name": "toolSelectClub"
    },
    {
      "parameters": {
        "sendTo": "chat",
        "chatId": "={{ $('Max Trigger').item.json.message.recipient.chat_id }}",
        "text": "={{ $json.output }}",
        "keyboard": "={{ $json.buttons ? JSON.stringify($json.buttons) : $json.keyboard }}"
      },
      "type": "n8n-nodes-max.max",
      "typeVersion": 1,
      "position": [620, 40],
      "id": "send-response",
      "name": "Send Response"
    }
  ],
  "connections": {
    "Max Trigger": { "main": [[{ "node": "Get User Context", "type": "main", "index": 0 }]] },
    "Get User Context": { "main": [[{ "node": "If User Not Linked", "type": "main", "index": 0 }], [{ "node": "If Multiple Clubs", "type": "main", "index": 0 }]] },
    "If User Not Linked": { "main": [[{ "node": "Send Link Request", "type": "main", "index": 0 }], [{ "node": "Prepare Data", "type": "main", "index": 0 }]] },
    "If Multiple Clubs": { "main": [[{ "node": "Build Club Buttons", "type": "main", "index": 0 }]] },
    "Build Club Buttons": { "main": [[{ "node": "If No Club Selected", "type": "main", "index": 0 }]] },
    "If No Club Selected": { "main": [[{ "node": "Send Club Selection", "type": "main", "index": 0 }], [{ "node": "Prepare Data", "type": "main", "index": 0 }]] },
    "Prepare Data": { "main": [[{ "node": "Chat Memory", "type": "main", "index": 0 }]] },
    "Chat Memory": { "ai_memory": [[{ "node": "AI Agent", "type": "ai_memory", "index": 0 }]] },
    "OpenRouter Model": { "ai_languageModel": [[{ "node": "AI Agent", "type": "ai_languageModel", "index": 0 }]] },
    "AI Agent": { "ai_tool": [[{ "node": "Tool Switch", "type": "ai_tool", "index": 0 }]] },
    "Tool Switch": { "main": [
      [{ "node": "toolGetRevenue", "type": "main", "index": 0 }],
      [{ "node": "toolGetShifts", "type": "main", "index": 0 }],
      [{ "node": "toolGetEmployees", "type": "main", "index": 0 }],
      [{ "node": "toolGetEmployeeHours", "type": "main", "index": 0 }],
      [{ "node": "toolSelectClub", "type": "main", "index": 0 }]
    ]},
    "toolGetRevenue": { "main": [[{ "node": "AI Agent", "type": "main", "index": 0 }]] },
    "toolGetShifts": { "main": [[{ "node": "AI Agent", "type": "main", "index": 0 }]] },
    "toolGetEmployees": { "main": [[{ "node": "AI Agent", "type": "main", "index": 0 }]] },
    "toolGetEmployeeHours": { "main": [[{ "node": "AI Agent", "type": "main", "index": 0 }]] },
    "toolSelectClub": { "main": [[{ "node": "AI Agent", "type": "main", "index": 0 }]] },
    "AI Agent": { "main": [[{ "node": "Send Response", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "versionId": "dashadmin-v11",
  "id": "dashadmin-ai-workflow",
  "tags": ["dashadmin", "ai", "assistant"]
}