        @keyframes bump {
          0% {
            transform: scale(1);
          }
          50% {
            transform: scale(1.3);
          }
          100% {
            transform: scale(1);
          }
        }
        .animate-bump {
          animation: bump 0.3s ease-out;
        }
      `}</style>
      </div>
    </div>
  );
}
