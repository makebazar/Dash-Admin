{
  "name": "dash-admin",
  "main": "electron/main.cjs",
  "version": "0.1.0",
  "private": true,
  "description": "DashAdmin экран",
  "author": "DashAdmin",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:next": "next dev",
    "dev:player": "vite --config player-app/vite.config.ts",
    "dev:signage": "concurrently -k \"npm run dev:player\" \"npm run electron:dev\"",
    "electron:dev": "wait-on tcp:3020 tcp:3000 && cross-env ELECTRON_START_URL=http://127.0.0.1:3020 DASHADMIN_SERVER_URL=http://127.0.0.1:3000 ELECTRON_USER_DATA_DIR=.electron-data ELECTRON_NO_SANDBOX=1 ELECTRON_DISABLE_GPU=1 electron electron/main.cjs",
    "electron:start": "electron electron/main.cjs",
    "electron:clean": "node scripts/clean_electron_dist.cjs",
    "build:player": "vite build --config player-app/vite.config.ts",
    "electron:prepare": "node scripts/generate_icon_png.cjs && npm run build:player && node scripts/prepare_electron_app.cjs",
    "electron:pack": "npm run electron:clean && npm run electron:prepare && electron-builder --dir",
    "electron:dist": "npm run electron:clean && npm run electron:prepare && electron-builder",
    "electron:dist:win": "npm run electron:clean && npm run electron:prepare && electron-builder --win nsis --x64",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.994.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-bubble-menu": "^3.20.1",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-floating-menu": "^3.20.1",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/bcrypt": "^6.0.0",
    "@types/react-input-mask": "^3.0.6",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.562.0",
    "next": "^15.5.9",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "quill": "^2.0.3",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-input-mask": "^2.0.4",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.3.2",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.dashadmin.screen",
    "productName": "DashAdmin экран",
    "directories": {
      "app": ".electron-app",
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "**/*",
      "!node_modules/**/*"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DashAdmin экран"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Office"
    }
  }
}
