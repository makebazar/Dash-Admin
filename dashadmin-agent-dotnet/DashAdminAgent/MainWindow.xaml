<Window x:Class="DashAdminAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DashAdmin Agent"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}">
  
  <Grid Margin="0">
    <Grid.RowDefinitions>
      <RowDefinition Height="60" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header Bar -->
    <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="{StaticResource PanelStroke}" BorderThickness="0,0,0,1">
      <Grid Margin="24,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        
        <!-- Logo & Title -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{StaticResource Accent}" CornerRadius="6" Padding="8,4" Margin="0,0,12,0">
            <TextBlock Text="DA" Foreground="White" FontWeight="Bold" FontSize="12" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="DashAdmin Agent" FontSize="15" FontWeight="600" Foreground="{StaticResource TextPrimary}" />
            <TextBlock Text="Привязка рабочего места · Телеметрия · Устройства" FontSize="11" Foreground="{StaticResource TextSecondary}" />
          </StackPanel>
        </StackPanel>

        <!-- Status Pill -->
        <Border Grid.Column="1"
                Background="{Binding StatusBg}"
                BorderBrush="{Binding StatusBorder}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="14,8"
                VerticalAlignment="Center"
                Margin="0,0,16,0">
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8" Height="8" Fill="{Binding StatusDot}" Margin="0,0,8,0" />
            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusTextColor}" FontWeight="500" FontSize="12" />
          </StackPanel>
        </Border>

        <!-- Window Controls -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Content="—" Style="{StaticResource ButtonGhost}" FontSize="16" Padding="12,6" Click="Minimize_Click" />
          <Button Content="✕" Style="{StaticResource ButtonGhost}" FontSize="13" Padding="10,6" Margin="4,0,0,0" Click="Close_Click" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid Grid.Row="1" Margin="20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" />
        <ColumnDefinition Width="20" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Left Sidebar -->
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Connection Panel -->
        <Border Background="#FFFFFF" CornerRadius="16" Padding="20" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
          <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Direction="270" />
          </Border.Effect>
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
              <Border Background="{StaticResource AccentLight}" CornerRadius="6" Padding="6,4" Margin="0,0,10,0">
                <TextBlock Text="🔗" FontSize="14" />
              </Border>
              <TextBlock Text="Подключение" FontSize="14" FontWeight="600" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Margin="0,0,0,16">
              <TextBlock Text="Код привязки" FontSize="12" Foreground="{StaticResource TextSecondary}" FontWeight="500" Margin="0,0,0,8" />
              <TextBox Text="{Binding BindingCode, UpdateSourceTrigger=PropertyChanged}" FontSize="13" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
              <Button Content="Привязать" Click="Bind_Click" Width="130" />
              <Button Content="Отвязать" Style="{StaticResource ButtonInline}" Click="Unbind_Click" Width="100" Margin="10,0,0,0" />
            </StackPanel>

            <Border Height="1" Background="{StaticResource PanelStroke}" Margin="0,0,0,20" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
              <Button Content="🌐 Открыть сайт" Style="{StaticResource ButtonInline}" Click="OpenDashboard_Click" />
              <Button Content="📥 В трей" Style="{StaticResource ButtonInline}" Click="ToTray_Click" Margin="10,0,0,0" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Hint Panel -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="16" Margin="0,16,0,0" Padding="20" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
          <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Direction="270" />
          </Border.Effect>
          <StackPanel VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
              <Border Background="#FFF9E6" CornerRadius="6" Padding="6,4" Margin="0,0,10,0">
                <TextBlock Text="💡" FontSize="14" />
              </Border>
              <TextBlock Text="Подсказка" FontSize="13" FontWeight="600" Foreground="{StaticResource TextPrimary}" />
            </StackPanel>
            <TextBlock Text="{Binding HintText}" FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="18" />
          </StackPanel>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
          <TextBlock Text="DashAdmin Agent" FontSize="11" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" />
          <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource TextTertiary}" />
          <TextBlock Text="v0.1" FontSize="11" Foreground="{StaticResource TextTertiary}" />
        </StackPanel>
      </Grid>

      <!-- Right Content Area -->
      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Telemetry Header -->
        <Border Background="#FFFFFF" CornerRadius="16" Padding="20" Margin="0,0,0,16" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
          <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Direction="270" />
          </Border.Effect>
          <Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
              <Border Background="{StaticResource AccentLight}" CornerRadius="6" Padding="6,4" Margin="0,0,10,0">
                <TextBlock Text="📊" FontSize="14" />
              </Border>
              <TextBlock Text="Телеметрия" FontSize="14" FontWeight="600" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondary}">
              <Run Text="Обновляется каждые " />
              <Run Text="2" FontWeight="500" />
              <Run Text=" сек" />
            </TextBlock>
          </Grid>
        </Border>

        <!-- Stats Cards Row -->
        <Grid Grid.Row="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <!-- CPU & GPU Cards -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- CPU Card -->
            <Border Background="#FFFFFF" CornerRadius="16" Padding="18" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.06" Direction="270" />
              </Border.Effect>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                  <Border Background="#FFEDE8" CornerRadius="6" Padding="6,4" Margin="0,0,8,0">
                    <TextBlock Text="🖥️" FontSize="12" />
                  </Border>
                  <TextBlock Text="Процессор" FontSize="12" FontWeight="600" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding CpuTempText}" FontSize="32" FontWeight="700" Foreground="{StaticResource TextPrimary}" Margin="0,12,0,0" />

                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                  <TextBlock Text="{Binding CpuNameText}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding CpuLoadText}" FontSize="12" Foreground="{StaticResource TextPrimary}" FontWeight="500" Margin="0,6,0,0" />
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,16,0,0">
                  <ProgressBar Value="{Binding CpuLoad}" Maximum="100" Height="6" />
                </Grid>
              </Grid>
            </Border>

            <!-- GPU Card -->
            <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="16" Padding="18" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.06" Direction="270" />
              </Border.Effect>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                  <Border Background="#E8F5E9" CornerRadius="6" Padding="6,4" Margin="0,0,8,0">
                    <TextBlock Text="🎮" FontSize="12" />
                  </Border>
                  <TextBlock Text="Видеокарта" FontSize="12" FontWeight="600" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding GpuTempText}" FontSize="32" FontWeight="700" Foreground="{StaticResource TextPrimary}" Margin="0,12,0,0" />

                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                  <TextBlock Text="{Binding GpuNameText}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding GpuLoadText}" FontSize="12" Foreground="{StaticResource TextPrimary}" FontWeight="500" Margin="0,6,0,0" />
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,16,0,0">
                  <ProgressBar Value="{Binding GpuLoad}" Maximum="100" Height="6" />
                </Grid>
              </Grid>
            </Border>
          </Grid>

          <!-- Memory & Disks Row -->
          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Memory Card -->
            <Border Background="#FFFFFF" CornerRadius="16" Padding="18" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.06" Direction="270" />
              </Border.Effect>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                  <Border Background="#E3F2FD" CornerRadius="6" Padding="6,4" Margin="0,0,8,0">
                    <TextBlock Text="💾" FontSize="12" />
                  </Border>
                  <TextBlock Text="Оперативная память" FontSize="12" FontWeight="600" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding MemoryText}" FontSize="28" FontWeight="700" Foreground="{StaticResource TextPrimary}" Margin="0,12,0,0" />
                
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                  <Border Background="#F0F0F0" CornerRadius="4" Padding="8,6">
                    <TextBlock Text="16 GB" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                  </Border>
                  <Border Background="#F0F0F0" CornerRadius="4" Padding="8,6" Margin="8,0,0,0">
                    <TextBlock Text="DDR4" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                  </Border>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Disks Card -->
            <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="16" Padding="18" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1">
              <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.06" Direction="270" />
              </Border.Effect>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                  <Border Background="#FFF3E0" CornerRadius="6" Padding="6,4" Margin="0,0,8,0">
                    <TextBlock Text="💿" FontSize="12" />
                  </Border>
                  <TextBlock Text="Диски" FontSize="12" FontWeight="600" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding Disks}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                  <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                      <Setter Property="Padding" Value="0,8" />
                      <Setter Property="Margin" Value="0" />
                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="ListViewItem">
                            <Border BorderBrush="{StaticResource PanelStroke}" BorderThickness="0,0,0,1" Padding="0,8">
                              <ContentPresenter />
                            </Border>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </ListView.ItemContainerStyle>
                  <ListView.ItemTemplate>
                    <DataTemplate>
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="60" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Mount}" FontSize="12" FontWeight="600" Foreground="{StaticResource TextPrimary}" />
                        <TextBlock Grid.Column="1" Text="{Binding UsedText}" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                      </Grid>
                    </DataTemplate>
                  </ListView.ItemTemplate>
                </ListView>
              </Grid>
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Grid>

    <!-- Debug Panel (Toggle) -->
    <Border Grid.Row="1"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Visibility="{Binding IsDebugOpen, Converter={StaticResource BoolToVisibility}}"
            Margin="0,0,20,20">
      <Border Background="#FFFFFF" CornerRadius="12" Width="480" MaxHeight="300" BorderBrush="{StaticResource PanelStroke}" BorderThickness="1" Padding="16">
        <Border.Effect>
          <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.12" Direction="270" />
        </Border.Effect>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="🐛" FontSize="14" Margin="0,0,8,0" />
            <TextBlock Text="Отладка" FontSize="13" FontWeight="600" VerticalAlignment="Center" />
            <Button Content="Свернуть" Style="{StaticResource ButtonGhost}" HorizontalAlignment="Right" Margin="280,0,0,0" Padding="10,6" FontSize="11" Click="ToggleDebug_Click" />
          </StackPanel>
          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>
            <ListView ItemsSource="{Binding Logs}" SelectedItem="{Binding SelectedLog}" Background="Transparent" BorderThickness="0">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Время" Width="60" DisplayMemberBinding="{Binding Time}" />
                  <GridViewColumn Header="Уровень" Width="60" DisplayMemberBinding="{Binding Level}" />
                  <GridViewColumn Header="Событие" Width="200" DisplayMemberBinding="{Binding Message}" />
                </GridView>
              </ListView.View>
            </ListView>
            <TextBox Grid.Column="2"
                     Text="{Binding SelectedLog.Detail}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="{StaticResource ControlBgActive}"
                     BorderThickness="0"
                     FontSize="11"
                     FontFamily="Consolas" />
          </Grid>
        </Grid>
      </Border>
    </Border>
  </Grid>
</Window>